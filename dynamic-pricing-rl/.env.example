# Environment Configuration Example
# Copy this to .env and customize for your environment

# Python
PYTHONUNBUFFERED=1

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Streamlit Configuration
STREAMLIT_PORT=8501

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Model Configuration
MODEL_NAME=dqn_pricing_model
MODEL_PATH=models/dqn_pricing_model.pth

# Training Configuration
TRAINING_EPISODES=1000
TRAINING_BATCH_SIZE=64
TRAINING_LEARNING_RATE=0.001

# Docker Configuration
CONTAINER_NAME_API=dqn-pricing-api
CONTAINER_NAME_DASHBOARD=dqn-pricing-dashboard
CONTAINER_NAME_TRAINING=dqn-pricing-training

# Timezone (optional)
TZ=UTC
